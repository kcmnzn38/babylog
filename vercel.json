{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/export", "schedule": "0 18 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
